{
  // ───────────────────────────────────────────────────────────
  // Shape library. Each shape is a set of (u,v)-parametric
  // surface patches. Expressions may reference u, v, pi, e, and
  // any ArbitraryShapeParams property (CenterX, Radius, Height,
  // MajorRadius, MinorRadius, AngleStartDeg, AngleSpanDeg,
  // SphereRadius, ConeTopRadius, ConeBottomRadius, ConeHeight,
  // RadialSegments, TubularSegments, HelixTurns, HelixPitch).
  //
  // Functions: sin cos tan asin acos atan atan2 sqrt abs floor
  //            ceil round sign exp log min max pow rad deg
  // Default winding gives outward normals for these radial
  // surfaces; set flipWinding:true to reverse.
  // ───────────────────────────────────────────────────────────
  "shapes": [
    {
      "name": "Cylinder",
      "volume": "pi * Radius^2 * Height",
      "patches": [
        {
          "uDomain":  ["0", "2*pi"],
          "vDomain":  ["0", "1"],
          "uSegments": "max(8, RadialSegments)",
          "vSegments": "max(2, TubularSegments)",
          "x": "Radius * cos(u)",
          "y": "-Height/2 + Height * v",
          "z": "Radius * sin(u)"
        },
        {
          "uDomain":  ["0", "2*pi"],
          "vDomain":  ["0", "1"],
          "uSegments": "max(8, RadialSegments)",
          "vSegments": "1",
          "flipWinding": true,
          "x": "Radius * v * cos(u)",
          "y": "Height/2",
          "z": "Radius * v * sin(u)"
        },
        {
          "uDomain":  ["0", "2*pi"],
          "vDomain":  ["0", "1"],
          "uSegments": "max(8, RadialSegments)",
          "vSegments": "1",
          "x": "Radius * v * cos(u)",
          "y": "-Height/2",
          "z": "Radius * v * sin(u)"
        }
      ]
    },

    {
      "name": "Sphere",
      "volume": "(4/3) * pi * SphereRadius^3",
      "patches": [
        {
          "uDomain":  ["0", "pi"],
          "vDomain":  ["0", "2*pi"],
          "uSegments": "max(8, TubularSegments)",
          "vSegments": "max(8, RadialSegments)",
          "x": "SphereRadius * sin(u) * cos(v)",
          "y": "SphereRadius * cos(u)",
          "z": "SphereRadius * sin(u) * sin(v)"
        }
      ]
    },

    {
      "name": "Cone",
      "volume": "pi * ConeHeight / 3 * (ConeBottomRadius^2 + ConeBottomRadius*ConeTopRadius + ConeTopRadius^2)",
      "patches": [
        {
          "uDomain":  ["0", "2*pi"],
          "vDomain":  ["0", "1"],
          "uSegments": "max(8, RadialSegments)",
          "vSegments": "max(2, TubularSegments)",
          "x": "(ConeBottomRadius + v*(ConeTopRadius - ConeBottomRadius)) * cos(u)",
          "y": "-ConeHeight/2 + ConeHeight * v",
          "z": "(ConeBottomRadius + v*(ConeTopRadius - ConeBottomRadius)) * sin(u)"
        }
      ]
    },

    {
      "name": "Torus",
      "volume": "2 * pi^2 * MajorRadius * MinorRadius^2",
      "patches": [
        {
          "uDomain":  ["0", "2*pi"],
          "vDomain":  ["0", "2*pi"],
          "uSegments": "max(8, RadialSegments)",
          "vSegments": "max(8, TubularSegments)",
          "x": "(MajorRadius + MinorRadius * cos(v)) * cos(u)",
          "y": "MinorRadius * sin(v)",
          "z": "(MajorRadius + MinorRadius * cos(v)) * sin(u)"
        }
      ]
    },

    {
      "name": "BoundedToroid",
      "volume": "2 * pi^2 * MajorRadius * MinorRadius^2 * (AngleSpanDeg/360)",
      "patches": [
        {
          "uDomain":  ["rad(AngleStartDeg)", "rad(AngleStartDeg + AngleSpanDeg)"],
          "vDomain":  ["0", "2*pi"],
          "uSegments": "max(8, RadialSegments)",
          "vSegments": "max(8, TubularSegments)",
          "x": "(MajorRadius + MinorRadius * cos(v)) * cos(u)",
          "y": "MinorRadius * sin(v)",
          "z": "(MajorRadius + MinorRadius * cos(v)) * sin(u)"
        },
        {
          "uDomain":  ["0", "2*pi"],
          "vDomain":  ["0", "1"],
          "uSegments": "max(8, TubularSegments)",
          "vSegments": "1",
          "x": "(MajorRadius + MinorRadius * v * cos(u)) * cos(rad(AngleStartDeg))",
          "y": "MinorRadius * v * sin(u)",
          "z": "(MajorRadius + MinorRadius * v * cos(u)) * sin(rad(AngleStartDeg))"
        },
        {
          "uDomain":  ["0", "2*pi"],
          "vDomain":  ["0", "1"],
          "uSegments": "max(8, TubularSegments)",
          "vSegments": "1",
          "flipWinding": true,
          "x": "(MajorRadius + MinorRadius * v * cos(u)) * cos(rad(AngleStartDeg + AngleSpanDeg))",
          "y": "MinorRadius * v * sin(u)",
          "z": "(MajorRadius + MinorRadius * v * cos(u)) * sin(rad(AngleStartDeg + AngleSpanDeg))"
        }
      ]
    },

    {
      "name": "Helix",
      "volume": "2 * pi^2 * MajorRadius * MinorRadius^2 * HelixTurns",
      "patches": [
        {
          "uDomain":  ["0", "2*pi*HelixTurns"],
          "vDomain":  ["0", "2*pi"],
          "uSegments": "max(8, RadialSegments) * max(1, ceil(HelixTurns))",
          "vSegments": "max(8, TubularSegments)",
          "x": "(MajorRadius + MinorRadius * cos(v)) * cos(u)",
          "y": "MinorRadius * sin(v) + HelixPitch * u / (2*pi)",
          "z": "(MajorRadius + MinorRadius * cos(v)) * sin(u)"
        }
      ]
    },
	
	{
	  "name": "HelicalToroid",
	  "volume": "2 * pi^2 * MajorRadius * MinorRadius^2 * (AngleSpanDeg/360)",
	  "patches": [
		{
		  "uDomain":   ["rad(AngleStartDeg)", "rad(AngleStartDeg + AngleSpanDeg)"],
		  "vDomain":   ["0", "2*pi"],
		  "uSegments": "max(8, RadialSegments) * max(1, ceil(HelixTurns))",
		  "vSegments": "max(8, TubularSegments)",

		  "x": "(MajorRadius + MinorRadius*cos(HelixTurns*u))*cos(u)  +  WireRadius*(cos(v)*_Tz/_Tn - sin(v)*_Ty*_Tx / (_Tn*_Tl))",
		  "y": " MinorRadius*sin(HelixTurns*u)                        +  WireRadius*( sin(v)*_Tn / _Tl )",
		  "z": "(MajorRadius + MinorRadius*cos(HelixTurns*u))*sin(u)  +  WireRadius*(cos(v)*(-_Tx)/_Tn - sin(v)*_Ty*_Tz / (_Tn*_Tl))"
		}
	  ]
	}

  ]
}